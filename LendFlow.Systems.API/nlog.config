<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/2002/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="temp\internal-nlog.txt">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>

	<targets>
		<!-- Time-Based Rolling File Target (30-day limit) -->
		<target xsi:type="File"
				name="auditFile"
				fileName="logs\lendflow-current.log"
				archiveFileName="logs\archives\lendflow-auditInternal-${shortdate}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				concurrentWrites="true"
				keepFileOpen="false"
				layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception:format=tostring}" />

		<!-- Console Target for real-time development tracking -->
		<target xsi:type="Console" name="debugConsole"
				layout="${longdate} | ${level:uppercase=true} | ${message}" />
	</targets>

	<rules>
		<!-- Global HTTP request logging strictly to console -->
		<logger name="Microsoft.AspNetCore.Hosting.Diagnostics" minlevel="Info" writeTo="debugConsole" final="true" />
		<logger name="Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware" minlevel="Info" writeTo="debugConsole" final="true" />

		<!-- Business/Service tracking to both file and console -->
		<logger name="LendFlow.Systems.BLL.*" minlevel="Info" writeTo="auditFile,debugConsole" />

		<!-- Discard remaining framework noise -->
		<logger name="Microsoft.*" maxlevel="Info" final="true" />
	</rules>
</nlog>
